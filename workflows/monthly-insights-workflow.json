    {
      "parameters": {
        "jsCode": "const summary = {};\n\nfor (const item of items) {\n\n  const category = item.json.Category;\n  const amount = Number(item.json.Amount);\n\n  if (!summary[category]) {\n    summary[category] = 0;\n  }\n\n  summary[category] += amount;\n}\n\nconst result = Object.entries(summary).map(([category, total]) => ({\n  category,\n  total\n}));\n\nreturn [{\n  json: {\n    spending_summary: result\n  }\n}];"
      },
