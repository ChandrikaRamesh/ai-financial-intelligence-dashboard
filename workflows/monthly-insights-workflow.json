    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const text =\n  $json.output[0].content[0].text;\n\nfunction extract(label) {\n  const regex = new RegExp(label + \":\\\\s*(.*)\");\n  const match = text.match(regex);\n  return match ? match[1].trim() : \"\";\n}\n\nconst score =\n  Number(extract(\"Savings Score\"));\n\nlet score_label = \"\";\n\nif (score >= 80) {\n  score_label = \"Excellent\";\n}\nelse if (score >= 60) {\n  score_label = \"Good\";\n}\nelse {\n  score_label = \"Needs Improvement\";\n}\n\nreturn {\n  json: {\n\n    month:\n      new Date().toLocaleString(\n        'en-US',\n        {\n          month: 'long',\n          year: 'numeric'\n        }\n      ),\n\n    top_insight:\n      extract(\"Top Insight\"),\n\n    warning:\n      extract(\"Warning\"),\n\n    recommendation:\n      extract(\"Recommendation\"),\n\n    savings_score:\n      score,\n\n    savings_label:\n      score_label\n  }\n};"
      },
